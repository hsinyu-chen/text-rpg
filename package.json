{
  "name": "text-rpg",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "node tools/dev-cert.cjs && ng serve --ssl --ssl-cert .certs/dev.pem --ssl-key .certs/dev-key.pem --host 0.0.0.0",
    "start:plain": "ng serve",
    "start:pwa": "npm run build && node tools/dev-cert.cjs && node tools/serve-dist.cjs",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "tauri": "tauri",
    "desktop": "tauri dev",
    "build:desktop": "tauri build",
    "build:desktop:bin": "tauri build --no-bundle",
    "lint": "ng lint --fix",
    "test": "ng test",
    "gen:icons": "node tools/gen-icons.cjs",
    "prompts:build": "tsx prompts/tool/build-prompts.ts",
    "prompts:check": "tsx prompts/tool/build-prompts.ts --check"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "license": "AGPL-3.0-or-later",
  "packageManager": "npm@11.6.1",
  "dependencies": {
    "@angular/animations": "^21.0.6",
    "@angular/cdk": "^21.0.5",
    "@angular/common": "^21.0.0",
    "@angular/compiler": "^21.0.0",
    "@angular/core": "^21.0.0",
    "@angular/forms": "^21.0.0",
    "@angular/material": "^21.0.5",
    "@angular/platform-browser": "^21.0.0",
    "@angular/router": "^21.0.0",
    "@angular/service-worker": "21.0.6",
    "@aws-sdk/client-s3": "^3.1037.0",
    "@google/genai": "^1.34.0",
    "@tauri-apps/api": "^2.9.1",
    "@tauri-apps/plugin-deep-link": "^2.4.5",
    "@tauri-apps/plugin-dialog": "^2.4.2",
    "@tauri-apps/plugin-fs": "^2.4.4",
    "@tauri-apps/plugin-shell": "^2.3.3",
    "@types/diff": "^7.0.2",
    "best-effort-json-parser": "^1.2.1",
    "diff": "^8.0.2",
    "idb": "^8.0.3",
    "katex": "^0.16.45",
    "marked": "^17.0.1",
    "monaco-editor": "^0.55.1",
    "ngx-markdown": "^21.0.1",
    "phaser": "^3.90.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.0.4",
    "@angular/cli": "^21.0.4",
    "@angular/compiler-cli": "^21.0.0",
    "@tauri-apps/cli": "^2.9.6",
    "@types/katex": "^0.16.8",
    "angular-eslint": "21.1.0",
    "eslint": "^9.39.1",
    "happy-dom": "^20.9.0",
    "sharp": "^0.34.5",
    "tsx": "^4.21.0",
    "typescript": "~5.9.2",
    "typescript-eslint": "8.47.0",
    "vitest": "^4.1.5"
  }
}
